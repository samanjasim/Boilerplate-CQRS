{
  "_WARNING": "Override ALL secrets (ConnectionStrings, JwtSettings.Secret, RabbitMQ, SeedSettings) via environment variables or user-secrets in production. Values below are DEVELOPMENT DEFAULTS only.",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=starterdb;Username=postgres;Password=123456",
    "Redis": "localhost:6379"
  },
  "DatabaseSettings": {
    "ApplyMigrationsOnStartup": false,
    "SeedDataOnStartup": false
  },
  "SeedSettings": {
    "SuperAdmin": {
      "Username": "superadmin",
      "Email": "superadmin@starter.com",
      "FirstName": "Super",
      "LastName": "Admin",
      "Password": "Admin@123456"
    }
  },
  "RabbitMQ": {
    "Host": "127.0.0.1",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  },
  "JwtSettings": {
    "Secret": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "Starter.Api",
    "Audience": "Starter.Client",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "SmtpSettings": {
    "Host": "localhost",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromEmail": "noreply@starter.com",
    "FromName": "Starter",
    "EnableSsl": true
  },
  "TwilioSettings": {
    "Enabled": false,
    "AccountSid": "",
    "AuthToken": "",
    "FromNumber": ""
  },
  "AblySettings": {
    "Enabled": false,
    "ApiKey": ""
  },
  "StorageSettings": {
    "Provider": "s3",
    "BucketName": "",
    "Endpoint": "",
    "AccessKey": "",
    "SecretKey": "",
    "Region": "us-east-1",
    "ForcePathStyle": false,
    "SignedUrlExpirationMinutes": 60
  },
  "AppSettings": {
    "FrontendUrl": "http://localhost:3000"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000"
    ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 10
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*/auth/login",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "*/auth/register",
        "Period": "1h",
        "Limit": 10
      }
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/starter-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
