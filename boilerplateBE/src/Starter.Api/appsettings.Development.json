{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=starterdb;Username=postgres;Password=123456",
    "Redis": "127.0.0.1:6379,abortConnect=false"
  },
  "DatabaseSettings": {
    "ApplyMigrationsOnStartup": true,
    "SeedDataOnStartup": true,
    "ResetDatabase": false
  },
  "SeedSettings": {
    "SuperAdmin": {
      "Username": "superadmin",
      "Email": "superadmin@starter.com",
      "FirstName": "Super",
      "LastName": "Admin",
      "Password": "Admin@123456"
    }
  },
  "RabbitMQ": {
    "Enabled": false,
    "Host": "127.0.0.1",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  },
  "JwtSettings": {
    "Secret": "DevSecretKeyThatIsAtLeast32CharactersLongForDevelopment!",
    "Issuer": "Starter.Api",
    "Audience": "Starter.Client",
    "AccessTokenExpirationMinutes": 120,
    "RefreshTokenExpirationDays": 30
  },
  "SmtpSettings": {
    "Host": "127.0.0.1",
    "Port": 1025,
    "FromEmail": "noreply@starter.com",
    "FromName": "Starter",
    "EnableSsl": false
  },
  "TwilioSettings": {
    "Enabled": false
  },
  "AblySettings": {
    "Enabled": false,
    "ApiKey": ""
  },
  "StorageSettings": {
    "Provider": "minio",
    "BucketName": "starter-files",
    "Endpoint": "http://127.0.0.1:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "Region": "us-east-1",
    "ForcePathStyle": true,
    "SignedUrlExpirationMinutes": 60
  },
  "AppSettings": {
    "FrontendUrl": "http://localhost:3000",
    "BaseDomain": "localhost"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 10
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*/auth/login",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "*/auth/register",
        "Period": "1h",
        "Limit": 10
      },
      {
        "Endpoint": "*/ai/search",
        "Period": "1m",
        "Limit": 30
      }
    ]
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "starter-api",
    "OtlpEndpoint": "http://127.0.0.1:4318"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/starter-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "AI": {
    "Enabled": true,
    "DefaultProvider": "Anthropic",
    "EmbeddingProvider": "OpenAI",
    "Providers": {
      "Anthropic": {
        "ChatModel": "claude-sonnet-4-20250514"
      }
    },
    "InstallDemoTemplatesOnStartup": true,
    "Rag": {
      "ChunkSize": 512,
      "ChunkOverlap": 50,
      "ParentChunkSize": 1536,
      "TopK": 5,
      "RetrievalTopK": 20,
      "EnableQueryExpansion": true,
      "EmbedBatchSize": 32,
      "MaxUploadBytes": 26214400,
      "OcrFallbackMinCharsPerPage": 40,
      "PageFailureThreshold": 0.25,
      "MaxContextTokens": 4000,
      "IncludeParentContext": true,
      "MinHybridScore": 0.0,
      "VectorWeight": 1.0,
      "KeywordWeight": 1.0,
      "RrfK": 60,
      "EmbeddingCacheTtlSeconds": 3600,
      "StageTimeoutEmbedMs": 5000,
      "StageTimeoutVectorMs": 5000,
      "StageTimeoutKeywordMs": 3000,
      "CircuitBreakers": {
        "Qdrant": {
          "Enabled": true,
          "MinimumThroughput": 10,
          "FailureRatio": 0.5,
          "BreakDurationMs": 30000
        },
        "PostgresFts": {
          "Enabled": true,
          "MinimumThroughput": 10,
          "FailureRatio": 0.5,
          "BreakDurationMs": 30000
        }
      },
      "FtsLanguage": "simple",
      "ApplyArabicNormalization": true,
      "NormalizeTaMarbuta": true,
      "NormalizeArabicDigits": true,

      "QueryRewriteMaxVariants": 3,
      "QueryRewriteCacheTtlSeconds": 1800,
      "StageTimeoutQueryRewriteMs": 8000,
      "RewriterModel": null,

      "RerankStrategy": "Auto",
      "RerankerModel": null,
      "ListwisePoolMultiplier": 3,
      "PointwisePoolMultiplier": 2,
      "PointwiseMaxParallelism": 5,
      "MinPointwiseScore": 0.3,
      "PointwiseMaxFailureRatio": 0.25,
      "RerankCacheTtlSeconds": 1800,
      "StageTimeoutRerankMs": 8000,

      "ClassifierModel": null,
      "QuestionCacheTtlSeconds": 1800,
      "StageTimeoutClassifyMs": 2000,

      "NeighborWindowSize": 1,
      "StageTimeoutNeighborMs": 3000,
      "NeighborScoreWeight": 0.5,

      "EnableStructuralChunking": true,
      "IncludeBreadcrumbInFts": true,

      "EnableContextualRewrite": true,
      "StageTimeoutContextualizeMs": 3000,
      "ContextualRewriteCacheTtlSeconds": 600,
      "ContextualRewriteHistoryTurns": 3,
      "ContextualRewriterModel": null,

      "EnableMmr": false,
      "MmrLambda": 0.7,
      "StageTimeoutMmrMs": 2000,

      "StageTimeoutAclResolveMs": 1500,
      "AclCacheTtlSeconds": 60
    }
  }
}
